# ── Google Apps Script API URL ────────────────────────────────
# วาง Deployment ID ของ Apps Script ที่นี่  ห้าม commit ไฟล์ .env จริง
VITE_API_URL=https://script.google.com/macros/s/AKfycbwe9SPRoGlyinPaakfnvQLYTvIcsUdawVQk3TKX9i9cGPo2YQIIObQ9XFm5pfj1kTrJ/exec

# ── GPS ออฟฟิศ ────────────────────────────────────────────────
# ละติจูด / ลองจิจูด ของออฟฟิศ (ค้นหาจาก Google Maps)
VITE_OFFICE_LAT=13.853706
VITE_OFFICE_LNG=100.504799

# ── รัศมีที่อนุญาต (เมตร) ────────────────────────────────────
VITE_GPS_RADIUS=100

# ── บัญชีทดสอบ (แสดงเฉพาะ dev mode — ไม่จำเป็นใน production) ─
VITE_DEMO_ADMIN_USER=
VITE_DEMO_ADMIN_PASS=
VITE_DEMO_EMP_USER=
VITE_DEMO_EMP_PASS=
